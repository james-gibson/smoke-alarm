{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ocd-smoke-alarm/self-description.schema.json",
  "title": "ocd-smoke-alarm self-description",
  "description": "Machine-readable description of an ocd-smoke-alarm instance, its capabilities, endpoints, and permission model. Designed for third-party clients and accessibility auditors.",
  "type": "object",
  "required": ["version", "service", "health", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "description": "JSON Schema reference for validation",
      "type": "string"
    },
    "version": {
      "description": "Self-description schema version",
      "type": "string",
      "const": "1"
    },
    "service": {
      "description": "Identity and operational mode of this instance",
      "type": "object",
      "required": ["name", "version", "mode"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "description": "Service name",
          "type": "string"
        },
        "mode": {
          "description": "Current operational mode",
          "type": "string",
          "enum": ["foreground", "background", "headless"]
        },
        "environment": {
          "description": "Deployment environment label",
          "type": "string"
        },
        "started_at": {
          "description": "ISO 8601 timestamp of instance start",
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "health": {
      "description": "Health and readiness endpoint paths",
      "type": "object",
      "required": ["endpoints"],
      "additionalProperties": false,
      "properties": {
        "listen_addr": {
          "description": "Address the health server is bound to",
          "type": "string"
        },
        "endpoints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "healthz": {
              "description": "Liveness probe path",
              "type": "string"
            },
            "readyz": {
              "description": "Readiness probe path",
              "type": "string"
            },
            "status": {
              "description": "Detailed status path (target states, regressions)",
              "type": "string"
            },
            "self_description": {
              "description": "Path serving this self-description document",
              "type": "string"
            }
          }
        }
      }
    },
    "capabilities": {
      "description": "What this instance can do, organized by category",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "monitoring": {
          "description": "Target monitoring capabilities",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "protocols": {
              "description": "Protocols this instance can validate",
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["mcp", "acp", "http"]
              }
            },
            "transports": {
              "description": "Transport types supported for probing",
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["http", "https", "sse", "websocket", "stdio"]
              }
            },
            "handshake_profiles": {
              "description": "Available handshake validation depths",
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["none", "base", "strict"]
              }
            },
            "regression_detection": {
              "description": "Whether known-good baseline tracking is enabled",
              "type": "boolean"
            },
            "safety_checks": {
              "description": "Whether HURL pre-protocol safety checks are enabled",
              "type": "boolean"
            }
          }
        },
        "discovery": {
          "description": "Target discovery capabilities",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "sources": {
              "description": "Active discovery source types",
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "static",
                  "environment",
                  "local_proxy",
                  "cloud_catalog",
                  "llms_txt"
                ]
              }
            },
            "llms_txt_uris": {
              "description": "Registered authoritative llms.txt URIs being fetched",
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "hosted": {
          "description": "Embedded MCP/ACP endpoints hosted by this instance",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "listen_addr": {
              "type": "string"
            },
            "endpoints": {
              "description": "Hosted protocol endpoint paths",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mcp": { "type": "string" },
                "acp": { "type": "string" },
                "a2a": { "type": "string" }
              }
            },
            "transports": {
              "description": "Transports enabled for hosted endpoints",
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["http", "sse"]
              }
            },
            "protocols": {
              "description": "Protocols enabled for hosted endpoints",
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["mcp", "acp", "a2a"]
              }
            }
          }
        },
        "dynamic_config": {
          "description": "Dynamic config artifact generation",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "formats": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["json", "markdown"]
              }
            },
            "serve_base_url": {
              "description": "Base URL for static serving of generated artifacts",
              "type": "string"
            }
          }
        },
        "meta_config": {
          "description": "Meta-config template generation for mcp-add",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "formats": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["yaml", "json"]
              }
            }
          }
        },
        "federation": {
          "description": "Multi-instance federation (experimental)",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "role": {
              "description": "Current federation role",
              "type": "string",
              "enum": ["introducer", "follower", "standalone"]
            }
          }
        }
      }
    },
    "permissions": {
      "description": "What this service reads, probes, and modifies. Follows ask/allow/deny convention.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesystem": {
          "description": "Filesystem access patterns",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": {
              "description": "Paths the service reads (configs, state, baseline files)",
              "type": "array",
              "items": { "type": "string" }
            },
            "write": {
              "description": "Paths the service writes (state dir, dynamic configs, lock files)",
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "network": {
          "description": "Network access patterns",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "probe": {
              "description": "What the service connects to for health checks",
              "type": "string",
              "enum": [
                "configured_targets_only",
                "discovery_derived",
                "unrestricted"
              ]
            },
            "listen": {
              "description": "Ports/addresses the service binds to",
              "type": "array",
              "items": { "type": "string" }
            },
            "outbound_domains": {
              "description": "Domains the service may contact (llms.txt fetches, cloud catalogs)",
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "secrets": {
          "description": "How the service handles credentials",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "keystore": {
              "description": "Whether OS keystore is used for secret material",
              "type": "boolean"
            },
            "env_refs": {
              "description": "Environment variable patterns used for secret injection",
              "type": "array",
              "items": { "type": "string" }
            },
            "redaction": {
              "description": "Whether auth fields are redacted in logs and status output",
              "type": "boolean"
            }
          }
        }
      }
    },
    "mcp": {
      "description": "MCP server configurations being monitored, using OpenCode-compatible shapes",
      "type": "object",
      "propertyNames": { "type": "string" },
      "additionalProperties": {
        "anyOf": [
          {
            "description": "Local MCP server (stdio command)",
            "type": "object",
            "required": ["type", "command"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "const": "local"
              },
              "command": {
                "description": "Command and arguments to run the MCP server",
                "type": "array",
                "items": { "type": "string" }
              },
              "environment": {
                "description": "Environment variables for the MCP server process",
                "type": "object",
                "propertyNames": { "type": "string" },
                "additionalProperties": { "type": "string" }
              },
              "enabled": { "type": "boolean" },
              "timeout": {
                "description": "Timeout in ms for MCP server requests",
                "type": "integer",
                "exclusiveMinimum": 0
              }
            }
          },
          {
            "description": "Remote MCP server (HTTP/SSE/WS)",
            "type": "object",
            "required": ["type", "url"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "const": "remote"
              },
              "url": {
                "description": "URL of the remote MCP server",
                "type": "string",
                "format": "uri"
              },
              "enabled": { "type": "boolean" },
              "headers": {
                "description": "Headers to send with requests",
                "type": "object",
                "propertyNames": { "type": "string" },
                "additionalProperties": { "type": "string" }
              },
              "oauth": {
                "description": "OAuth configuration (false to disable auto-detection)",
                "anyOf": [
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "client_id": { "type": "string" },
                      "client_secret_ref": {
                        "description": "Reference to client secret (env:// or keychain://)",
                        "type": "string"
                      },
                      "scope": { "type": "string" },
                      "token_url": {
                        "type": "string",
                        "format": "uri"
                      }
                    }
                  },
                  {
                    "type": "boolean",
                    "const": false
                  }
                ]
              },
              "timeout": {
                "description": "Timeout in ms for MCP server requests",
                "type": "integer",
                "exclusiveMinimum": 0
              }
            }
          }
        ]
      }
    },
    "targets": {
      "description": "Summary of monitored targets and their current state (populated at runtime)",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "protocol", "transport"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "protocol": {
            "type": "string",
            "enum": ["mcp", "acp", "http"]
          },
          "transport": {
            "type": "string",
            "enum": ["http", "https", "sse", "websocket", "stdio"]
          },
          "endpoint": { "type": "string" },
          "state": {
            "description": "Current health state (populated at runtime, absent in static file)",
            "type": "string",
            "enum": ["HEALTHY", "DEGRADED", "REGRESSION", "OUTAGE", "UNKNOWN"]
          },
          "auth_type": {
            "type": "string",
            "enum": ["none", "bearer", "apikey", "oauth"]
          },
          "handshake_profile": {
            "type": "string",
            "enum": ["none", "base", "strict"]
          },
          "enabled": { "type": "boolean" }
        }
      }
    }
  }
}
