{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/james-gibson/smoke-alarm/refs/heads/main/configs/schema/self-description.schema.json",
  "title": "Smoke Alarm Config",
  "description": "Configuration schema for smoke-alarm instances",
  "type": "object",
  "properties": {
    "version": { "type": "string" },

    "service": {
      "type": "object",
      "properties": {
        "name":          { "type": "string" },
        "environment":   { "type": "string" },
        "mode":          { "type": "string", "enum": ["foreground", "background"] },
        "log_level":     { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "poll_interval": { "type": "string", "description": "Duration string e.g. '10s', '5m'" },
        "timeout":       { "type": "string", "description": "Global timeout duration string" },
        "max_workers":   { "type": "integer" }
      }
    },

    "health": {
      "type": "object",
      "properties": {
        "enabled":     { "type": "boolean" },
        "listen_addr": { "type": "string" },
        "endpoints": {
          "type": "object",
          "properties": {
            "healthz": { "type": "string" },
            "readyz":  { "type": "string" },
            "status":  { "type": "string" }
          }
        }
      }
    },

    "runtime": {
      "type": "object",
      "properties": {
        "lock_file":                 { "type": "string" },
        "state_dir":                 { "type": "string" },
        "baseline_file":             { "type": "string" },
        "event_history_size":        { "type": "integer" },
        "graceful_shutdown_timeout": { "type": "string" },
        "session_ttl":               { "type": "string" }
      }
    },

    "discovery": {
      "type": "object",
      "properties": {
        "enabled":             { "type": "boolean" },
        "interval":            { "type": "string" },
        "include_local_paths": { "type": "array", "items": { "type": "string" } },
        "include_env_vars":    { "type": "array", "items": { "type": "string" } },
        "local_proxy_scan": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "hosts":   { "type": "array", "items": { "type": "string" } },
            "ports":   { "type": "array", "items": { "type": "integer" } }
          }
        },
        "cloud_catalog": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "urls":    { "type": "array", "items": { "type": "string" } }
          }
        },
        "llms_txt": {
          "type": "object",
          "properties": {
            "enabled":                 { "type": "boolean" },
            "remote_uris":             { "type": "array", "items": { "type": "string" } },
            "fetch_timeout":           { "type": "string" },
            "require_https":           { "type": "boolean" },
            "auto_register_as_targets":{ "type": "boolean" },
            "auto_register_oauth":     { "type": "boolean" }
          }
        }
      }
    },

    "alerts": {
      "type": "object",
      "properties": {
        "aggressive":                        { "type": "boolean" },
        "notify_on_regression_immediately":  { "type": "boolean" },
        "retry_before_escalation":           { "type": "integer" },
        "dedupe_window":                     { "type": "string" },
        "cooldown":                          { "type": "string" },
        "severity": {
          "type": "object",
          "properties": {
            "healthy":    { "type": "string" },
            "degraded":   { "type": "string" },
            "regression": { "type": "string" },
            "outage":     { "type": "string" }
          }
        },
        "sinks": {
          "type": "object",
          "properties": {
            "log": {
              "type": "object",
              "properties": { "enabled": { "type": "boolean" } }
            },
            "os_notification": {
              "type": "object",
              "properties": {
                "enabled":      { "type": "boolean" },
                "title_prefix": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "auth": {
      "type": "object",
      "properties": {
        "keystore": {
          "type": "object",
          "properties": {
            "enabled":  { "type": "boolean" },
            "provider": { "type": "string" }
          }
        },
        "redaction": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "mask":    { "type": "string" }
          }
        },
        "oauth": {
          "type": "object",
          "properties": {
            "enabled":                  { "type": "boolean" },
            "token_grace_period":       { "type": "string" },
            "unattended": {
              "type": "object",
              "properties": {
                "enabled":                   { "type": "boolean" },
                "allow_device_code":         { "type": "boolean" },
                "allow_client_credentials":  { "type": "boolean" },
                "allow_refresh_token":       { "type": "boolean" }
              }
            },
            "mock_redirect": {
              "type": "object",
              "properties": {
                "enabled":     { "type": "boolean" },
                "listen_addr": { "type": "string" },
                "path":        { "type": "string" },
                "mode":        { "type": "string", "enum": ["allow", "fail"] }
              }
            }
          }
        }
      }
    },

    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "protocol", "endpoint"],
        "properties": {
          "id":        { "type": "string" },
          "enabled":   { "type": "boolean" },
          "protocol":  { "type": "string", "enum": ["mcp", "acp", "http"] },
          "name":      { "type": "string" },
          "endpoint":  { "type": "string" },
          "transport": { "type": "string", "enum": ["http", "stdio", "sse"] },
          "stdio": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "args":    { "type": "array", "items": { "type": "string" } },
              "env":     { "type": "object", "additionalProperties": { "type": "string" } },
              "cwd":     { "type": "string" }
            }
          },
          "expected": {
            "type": "object",
            "properties": {
              "healthy_status_codes":  { "type": "array", "items": { "type": "integer" } },
              "min_capabilities":      { "type": "array", "items": { "type": "string" } },
              "known_agent_count_min": { "type": "integer" },
              "expected_version":      { "type": "string" }
            }
          },
          "auth": {
            "type": "object",
            "properties": {
              "type":         { "type": "string", "enum": ["none", "oauth", "bearer", "mtls"] },
              "client_id":    { "type": "string" },
              "token_url":    { "type": "string" },
              "redirect_url": { "type": "string" },
              "callback_id":  { "type": "string" },
              "secret_ref":   { "type": "string" },
              "scopes":       { "type": "array", "items": { "type": "string" } },
              "header":       { "type": "string" },
              "key_name":     { "type": "string" },
              "cert_ref":     { "type": "string" },
              "key_ref":      { "type": "string" }
            }
          },
          "check": {
            "type": "object",
            "properties": {
              "interval":          { "type": "string" },
              "timeout":           { "type": "string" },
              "retries":           { "type": "integer" },
              "handshake_profile": { "type": "string", "enum": ["strict", "none", "base"] },
              "required_methods":  { "type": "array", "items": { "type": "string" } },
              "hurl_tests": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name":     { "type": "string" },
                    "endpoint": { "type": "string" },
                    "method":   { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] }
                  }
                }
              }
            }
          }
        }
      }
    },

    "known_state": {
      "type": "object",
      "properties": {
        "enabled":                              { "type": "boolean" },
        "persist":                              { "type": "boolean" },
        "sustain_success_before_mark_healthy":  { "type": "integer" },
        "classify_new_failures_after_healthy_as": { "type": "string" },
        "outage_threshold_consecutive_failures":  { "type": "integer" }
      }
    },

    "meta_config": {
      "type": "object",
      "properties": {
        "enabled":             { "type": "boolean" },
        "output_dir":          { "type": "string" },
        "formats":             { "type": "array", "items": { "type": "string", "enum": ["yaml", "json", "markdown"] } },
        "include_confidence":  { "type": "boolean" },
        "include_provenance":  { "type": "boolean" },
        "placeholders":        { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },

    "dynamic_config": {
      "type": "object",
      "properties": {
        "enabled":            { "type": "boolean" },
        "directory":          { "type": "string" },
        "formats":            { "type": "array", "items": { "type": "string" } },
        "serve_base_url":     { "type": "string" },
        "allow_overwrite":    { "type": "boolean" },
        "require_unique_ids": { "type": "boolean" }
      }
    },

    "remote_agent": {
      "type": "object",
      "properties": {
        "managed_updates":    { "type": "boolean" },
        "control_endpoint":   { "type": "string" },
        "update": {
          "type": "object",
          "properties": {
            "strategy":            { "type": "string" },
            "stop_command":        { "type": "string" },
            "start_command":       { "type": "string" },
            "verify_command":      { "type": "string" },
            "rollback_on_failure": { "type": "boolean" },
            "max_wait_for_healthy":{ "type": "string" }
          }
        },
        "safety": {
          "type": "object",
          "properties": {
            "require_lock": { "type": "boolean" },
            "lock_ttl":     { "type": "string" }
          }
        }
      }
    },

    "hosted": {
      "type": "object",
      "properties": {
        "enabled":     { "type": "boolean" },
        "listen_addr": { "type": "string" },
        "transports":  { "type": "array", "items": { "type": "string", "enum": ["http", "sse"] } },
        "protocols":   { "type": "array", "items": { "type": "string", "enum": ["mcp", "acp", "a2a"] } },
        "endpoints": {
          "type": "object",
          "properties": {
            "mcp": { "type": "string" },
            "acp": { "type": "string" },
            "a2a": { "type": "string" }
          }
        }
      }
    },

    "federation": {
      "type": "object",
      "properties": {
        "enabled":              { "type": "boolean" },
        "base_port":            { "type": "integer" },
        "max_port":             { "type": "integer" },
        "poll_interval":        { "type": "string" },
        "announce_interval":    { "type": "string" },
        "heartbeat_interval":   { "type": "string" },
        "heartbeat_timeout":    { "type": "string" },
        "upstream":             { "type": "string" },
        "downstream":           { "type": "array", "items": { "type": "string" } },
        "rank":                 { "type": "integer" }
      }
    },

    "telemetry": {
      "type": "object",
      "properties": {
        "enabled":         { "type": "boolean" },
        "endpoint":        { "type": "string" },
        "service_name":    { "type": "string" },
        "export_interval": { "type": "string" }
      }
    },

    "tuner": {
      "type": "object",
      "properties": {
        "enabled":      { "type": "boolean" },
        "advertise":    { "type": "boolean" },
        "service_type": { "type": "string" },
        "audience": {
          "type": "object",
          "properties": {
            "enabled":  { "type": "boolean" },
            "endpoint": { "type": "string" }
          }
        },
        "caller_hook": {
          "type": "object",
          "properties": {
            "enabled":      { "type": "boolean" },
            "mcp_response": { "type": "boolean" }
          }
        }
      }
    }
  }
}
